# ──────────────────────────────────────────────────────────────────────
# LinkedIn Podcast Bot — environment configuration
# Copy this file to `.env` and fill in your own values.
# ──────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Primary AI provider — Groq (https://console.groq.com)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback AI provider — Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Optional tunables (defaults shown) --------------------------------
# Retry / timeout
# AI_MAX_RETRIES=3
# AI_REQUEST_TIMEOUT=60
# SCRAPE_TIMEOUT=20
# SCRAPE_MAX_RETRIES=3

# Text-to-Speech
# TTS_VOICE_FEMALE=fa-IR-DilaraNeural
# TTS_VOICE_MALE=fa-IR-FaridNeural
# TTS_RATE=-5%        # negative = slower
# TTS_VOLUME=+0%

# Logging
# LOG_LEVEL=INFO
